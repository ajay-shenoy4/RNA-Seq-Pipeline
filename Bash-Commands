#run star and nextflow and stuff with auto shutdown
# Kill the current processes
killall nextflow 2>/dev/null
pkill -f auto_shutdown.sh 2>/dev/null

# Wait a moment
sleep 2

# Start fresh with proper backgrounding
cd ~/rna-seq-project

# Start Nextflow
nohup nextflow run workflow/main.nf -c nextflow.config > nextflow.log 2>&1 &

# Give it a moment to initialize
sleep 3

# Start auto-shutdown monitor
nohup ./auto_shutdown.sh > auto_shutdown_console.log 2>&1 &

# Verify both are running properly
echo "=== Running Processes ==="
ps aux | grep -E "nextflow|auto_shutdown" | grep -v grep

echo -e "\n=== Nextflow Log (last 15 lines) ==="
tail -15 nextflow.log

echo -e "\n=== Auto-shutdown Log (last 10 lines) ==="
tail -10 auto_shutdown.log


# Kill all stopped jobs
kill $(jobs -p) 2>/dev/null

# Restart auto-shutdown monitor
cd ~/rna-seq-project
nohup ./auto_shutdown.sh >> auto_shutdown.log 2>&1 &

# Verify critical processes
echo "=== STAR Status ==="
ps aux | grep STAR | grep -v grep | head -2

echo -e "\n=== Auto-shutdown Status ==="
ps aux | grep auto_shutdown | grep -v grep

echo -e "\n=== Last few lines of auto-shutdown log ==="
tail -5 auto_shutdown.log

# Force exit (ignores stopped jobs)
exit -f

